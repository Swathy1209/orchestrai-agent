# ─────────────────────────────────────────────────────────────
# OrchestrAI Career Agent — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── GitHub Cloud YAML Database ────────────────────────────────
# Personal Access Token with repo read/write scope
GITHUB_TOKEN=your-github-personal-access-token-here

# Your GitHub username (used to construct repo slug)
GITHUB_USERNAME=Swathy1209

# Repository name only (not the full slug — username is added automatically)
# The repo should already exist: https://github.com/Swathy1209/orchestrai-db
GITHUB_REPO=Swathy1209/orchestrai-db

# Branch to read/write YAML files (default: main)
GITHUB_BRANCH=main

# ── OpenAI ────────────────────────────────────────────────────
# API key (GPT-3.5-turbo used for relevance filter)
# If left blank, falls back to keyword-based filtering
OPENAI_API_KEY=your-openai-api-key-here

# ── Email (SMTP) ──────────────────────────────────────────────
# Gmail address used to SEND the daily report
EMAIL_USER=your-gmail@gmail.com

# Gmail App Password (NOT your login password)
# Generate at: https://myaccount.google.com/apppasswords
# Requires 2FA to be enabled on your Google account
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# Email address(es) to RECEIVE the daily report
EMAIL_RECEIVER=your-receiver@gmail.com

# ── SMTP Server (defaults work for Gmail) ─────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
